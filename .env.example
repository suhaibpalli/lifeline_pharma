# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,lifelinehealthcare.in,www.lifelinehealthcare.in

# Database Settings
# For SQLite:
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# For PostgreSQL (Example):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=lifeline_db
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# Email Settings
EMAIL_BACKEND=apps.core.email_backend.ConfigurableSMTPEmailBackend
EMAIL_HOST=mail.suhaiblabs.info
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=me@suhaiblabs.info
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=me@suhaiblabs.info
EMAIL_VALIDATE_CERTS=False

# Site URL
SITE_URL=https://lifelinehealthcare.in

